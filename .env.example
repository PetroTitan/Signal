NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SIGNAL_DEMO_MODE=false

# =====================================================================
# Platform OAuth (Phase E3)
# =====================================================================
# Server-only. Do NOT use NEXT_PUBLIC_ prefixes — these are secrets.
# Leave blank to keep OAuth disabled; the UI surfaces "OAuth app not
# configured yet." in that case.

REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_REDIRECT_URI=https://signal.webmasterid.com/api/oauth/reddit/callback

# Phase F2.5 — Reddit API approval gating.
# Reddit's Responsible Builder Policy currently blocks our OAuth app
# provisioning. Setting this to "blocked_pending_reddit_api_approval"
# surfaces the block in the UI and routes /execution/items/<id> to
# the manual-publish fallback. Leave unset or set "enabled" once the
# Reddit app is approved and OAuth env vars are populated.
REDDIT_OAUTH_STATUS=blocked_pending_reddit_api_approval

X_CLIENT_ID=
X_CLIENT_SECRET=
X_REDIRECT_URI=

LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=

# Token encryption (Phase F2 — AES-256-GCM)
# Server-only. Never NEXT_PUBLIC_. When unset or malformed, Signal
# refuses to store OAuth tokens — the connection is recorded with
# status='error' and metadata.token_storage='not_configured'. The key
# must decode to exactly 32 bytes (AES-256). Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
# Both base64url and base64 are accepted.
TOKEN_ENCRYPTION_KEY=

# =====================================================================
# Signal MCP server (Phase F0)
# =====================================================================
# Server-only. Never bundled to the client. Used exclusively by the
# /api/mcp HTTP bridge to authorize external operator tokens. When
# unset, /api/mcp returns 503 honestly and the /settings/mcp page
# shows "Signal MCP Server: not configured."
SUPABASE_SERVICE_ROLE_KEY=

# =====================================================================
# Controlled-publish mode (Phase F2.5)
# =====================================================================
# SAFE_TEST_MODE=true enables the controlled Reddit publish surface:
#   - scheduler only moves eligible items to status='ready' (never
#     calls Reddit on its own)
#   - operator must visit /execution/items/<id>, review the preview,
#     type the confirmation phrase, and click Publish
#   - publishing scope `submit` is requested during Reddit OAuth
#   - rate limits: 1 per hour, 3 per 24h, no retries
#   - duplicate prevention: 30-day fingerprint window
# When false / unset, no live Reddit publish can be triggered.
SAFE_TEST_MODE=false

# Comma- or newline-separated list of subreddit names (no /r/ prefix).
# Posts to anywhere else are refused by the safe-test policy.
ALLOWED_TEST_SUBREDDITS=test,testingground4bots

# =====================================================================
# Cron auth (scheduler tick / notification digest / metrics refresh)
# =====================================================================
# The cron routes — /api/scheduler/tick, /api/notifications/digest,
# /api/metrics/refresh — accept EITHER of two shared secrets in the
#   Authorization: Bearer <secret>
# header. If NEITHER is set the routes return 503 (honestly disabled);
# a present secret with a bad/missing header returns 401.
#
#   CRON_SECRET          — REQUIRED for Vercel Cron. Vercel automatically
#                          sends `Authorization: Bearer $CRON_SECRET` on
#                          every scheduled invocation (it cannot send a
#                          custom header). Set this in the Vercel project
#                          env or the cron jobs will 401 and silently
#                          never run.
#   SCHEDULER_TICK_TOKEN — OPTIONAL. Retained for backward-compatible
#                          manual (curl) triggering and existing
#                          deployments. Safe to leave unset if you only
#                          rely on Vercel Cron.
#
# If you set both, they may hold different values; a request matching
# either one is authorized.
CRON_SECRET=
SCHEDULER_TICK_TOKEN=
